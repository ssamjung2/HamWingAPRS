# /etc/default/pi-sstv
# Environment overrides for pi-sstv.service

# Force known-good ALSA playback target
PI_SSTV_ALSA_DEVICE=plughw:CARD=Headphones,DEV=0

# Mixer guardrails
PI_SSTV_ALSA_ENFORCE_VOLUME=true
PI_SSTV_ALSA_MIXER_DEVICE=Headphones
PI_SSTV_ALSA_MIXER_CONTROL=PCM
PI_SSTV_ALSA_TARGET_VOLUME=70
PI_SSTV_ALSA_MAX_SAFE_VOLUME=85

# Playback timeout (seconds)
PI_SSTV_APLAY_TIMEOUT_SECONDS=240

# Optional: GPS overlay
# PI_SSTV_GPS_ENABLE=true
